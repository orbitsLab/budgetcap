## Phase 6 — Data Layer (React Query)

```ts
// lib/hooks/useEnvelopes.ts
export function useEnvelopes(month: number, year: number) {
  const { householdId } = useAuthStore();
  return useQuery({
    queryKey: ["envelopes", householdId, month, year],
    queryFn: () => apiFetch(`/api/envelopes?householdId=${householdId}&month=${month}&year=${year}`),
    staleTime: 1000 * 60 * 2, // 2 min
  });
}

// lib/hooks/useTransactions.ts
export function useTransactions(filters: TransactionFilters) { ... }

// lib/hooks/useAccounts.ts
export function useAccounts() { ... }
```

All mutations use `useMutation` with optimistic updates and cache invalidation.


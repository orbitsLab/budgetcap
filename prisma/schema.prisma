// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  householdMembers HouseholdMember[]
  ownedHouseholds  Household[]       @relation("HouseholdOwner")

  // NextAuth.js sessions (credentials-only, no OAuth sessions needed)
  sessions Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────
// HOUSEHOLD
// ─────────────────────────────────────────────────────────

model Household {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner   User              @relation("HouseholdOwner", fields: [ownerId], references: [id])
  members HouseholdMember[]

  envelopeSets EnvelopeSet[]
  transactions Transaction[]
  accounts     Account[]
}

model HouseholdMember {
  householdId String
  userId      String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([householdId, userId])
}

enum MemberRole {
  OWNER
  MEMBER
}

// ─────────────────────────────────────────────────────────
// ACCOUNTS (Checking, Savings, Cash)
// ─────────────────────────────────────────────────────────

/// A real-world financial account (bank account, cash, savings, etc.)
model Account {
  id          String      @id @default(cuid())
  householdId String
  name        String      // e.g. "Primary Account", "Savings", "Cash Jar"
  type        AccountType
  /// Opening / initial balance in paise
  openingBalanceInPaise Int     @default(0)
  isDefault   Boolean     @default(false)
  position    Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  envelopeSets EnvelopeSet[] // sections linked to this account
  transactions Transaction[] @relation("TransactionAccount")
  toTransactions Transaction[] @relation("TransactionToAccount")

  @@index([householdId, position])
}

enum AccountType {
  CHECKING
  SAVINGS
  CASH
}

// ─────────────────────────────────────────────────────────
// ENVELOPE BUDGETING
// ─────────────────────────────────────────────────────────

model EnvelopeSet {
  id          String   @id @default(cuid())
  householdId String
  /// Optional link to a real Account (e.g. "Monthly (Primary)")
  accountId   String?
  name        String
  position    Int      @default(0)
  /// Day of month this budget section starts (1–28), default 1st
  startsOnDay Int      @default(1)
  createdAt   DateTime @default(now())

  household Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  account   Account?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  envelopes Envelope[]

  @@index([householdId, position])
}

model Envelope {
  id            String   @id @default(cuid())
  envelopeSetId String
  name          String
  isArchived    Boolean  @default(false)
  position      Int      @default(0)
  /// If true, this envelope is a savings Goal (not a monthly spend category)
  isGoal        Boolean  @default(false)
  /// Target amount for this goal in paise (null = no goal set)
  goalAmountInPaise Int?
  /// Optional deadline for reaching the goal
  goalDeadline  DateTime?
  /// Default amount to fill this envelope with each month (in paise)
  initialAmountInPaise Int @default(0)
  createdAt     DateTime @default(now())

  envelopeSet  EnvelopeSet   @relation(fields: [envelopeSetId], references: [id], onDelete: Cascade)
  allocations  Allocation[]
  transactions Transaction[]
  transfersTo  Transaction[] @relation("TransferToEnvelope")

  @@index([envelopeSetId, position])
}

/// Monthly budget allocation for an envelope.
/// amountInPaise: integer representing paise (₹1 = 100 paise)
model Allocation {
  id            String @id @default(cuid())
  envelopeId    String
  /// 1–12
  month         Int
  /// e.g. 2025
  year          Int
  /// Stored in paise (never floats). ₹10.50 → 1050
  amountInPaise Int    @default(0)

  envelope Envelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)

  @@unique([envelopeId, month, year])
  @@index([envelopeId, year, month])
}

/// Financial transaction (income, expense, or transfer).
/// amountInPaise: always positive; type determines direction.
model Transaction {
  id          String          @id @default(cuid())
  householdId String
  envelopeId  String?
  /// For TRANSFER: the destination envelope
  toEnvelopeId String?
  /// Account this transaction was made from (optional)
  accountId    String?
  /// For account-to-account transfers: the destination account
  toAccountId  String?
  date        DateTime
  /// INCOME | EXPENSE | TRANSFER
  type        TransactionType
  /// Stored in paise (never floats)
  amountInPaise Int
  payee       String?
  notes       String?

  // Recurring transaction support
  isRecurring        Boolean @default(false)
  /// Day of month to auto-generate (1–28)
  recurringDayOfMonth Int?
  /// Track which transactions were auto-generated from a recurring template
  recurringParentId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  envelope    Envelope? @relation(fields: [envelopeId], references: [id], onDelete: SetNull)
  toEnvelope  Envelope? @relation("TransferToEnvelope", fields: [toEnvelopeId], references: [id], onDelete: SetNull)
  account     Account?  @relation("TransactionAccount", fields: [accountId], references: [id], onDelete: SetNull)
  toAccount   Account?  @relation("TransactionToAccount", fields: [toAccountId], references: [id], onDelete: SetNull)

  @@index([householdId, date])
  @@index([envelopeId, date])
  @@index([accountId, date])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}
